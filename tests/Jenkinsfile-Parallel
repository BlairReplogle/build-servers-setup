#!/usr/bin/env groovy

@Library('jenkins-shared-library') _

pipeline {
	parameters {
		string(name: 'NODE_LABEL_MOBILE', defaultValue: 'macos-latest', description: 'Mac node label')
		string(name: 'NODE_LABEL_WEB', defaultValue: 'ubuntu-latest', description: 'Web node label')
	}
	options {
		ansiColor('xterm')
		disableConcurrentBuilds(abortPrevious: true)
		skipStagesAfterUnstable()
	}
	stages {
		stage('run') {
			parallel {
				stage('Mac Tests') {
					agent {
						label params.NODE_LABEL_MOBILE
					}
					steps {
						osInfo()
						setupHomebrew()
						setupAsdf()
						setupAndroid()
						run_tests()
					}
				}
				stage('Web Tests') {
					agent {
						label params.NODE_LABEL_WEB
					}
					steps {
						osInfo()
						setupHomebrew()
						setupAsdf()
						setupAndroid()
						run_tests()
					}
				}
			}
		}

	}
	post {
		always {
			script {
				archiveArtifacts artifacts: 'web/*', allowEmptyArchive: false
			}
		}
	}
}

def run_tests() {
	sh """
		./tests/web.sh
	"""
}
