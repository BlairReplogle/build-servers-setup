#!/usr/bin/env groovy

@Library('jenkins-shared-library') _

pipeline {
	agent {
		label 'built-in'
	}
	parameters {
		string(name: 'NODE_LABEL_MOBILE', defaultValue: 'macos-latest', description: 'Mac node label')
		string(name: 'NODE_LABEL_WEB', defaultValue: 'ubuntu-latest', description: 'Web node label')
	}
	options {
		ansiColor('xterm')
		disableConcurrentBuilds(abortPrevious: true)
		skipStagesAfterUnstable()
	}
	stages {
		stage('run') {
			parallel {
				stage('Mac Tests') {
					agent {
						label params.NODE_LABEL_MOBILE
					}
					steps {
						osInfo()
						setupHomebrew()
						setupAsdf()
						setupAndroid()

						sh """
							./tests/mac.sh
						"""
					}
				}
				stage('Web Tests') {
					agent {
						label params.NODE_LABEL_WEB
					}
					steps {
						osInfo()
						setupHomebrew()
						setupAsdf()
						setupAndroid()
						script {
							run_web_tests()
						}
					}
				}
			}
		}
	}
}

def run_web_tests() {
	echo "run web tests..."

	sh """
		./tests/web.sh
	"""
}
